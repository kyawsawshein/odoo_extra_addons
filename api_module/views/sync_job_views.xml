<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sync Job List View -->
    <record id="view_sync_job_list" model="ir.ui.view">
        <field name="name">sync.job.list</field>
        <field name="model">sync.job</field>
        <field name="arch" type="xml">
            <list string="Sync Jobs" decoration-success="status=='success'" decoration-warning="status=='running'" decoration-danger="status=='failed'">
                <field name="config_id"/>
                <field name="job_type"/>
                <field name="status"/>
                <field name="records_processed"/>
                <field name="message" invisible="1"/>
                <field name="create_date"/>
                <field name="complete_date"/>
            </list>
        </field>
    </record>

    <!-- Sync Job Form View -->
    <record id="view_sync_job_form" model="ir.ui.view">
        <field name="name">sync.job.form</field>
        <field name="model">sync.job</field>
        <field name="arch" type="xml">
            <form string="Sync Job Details">
                <sheet>
                    <group>
                        <group string="Job Information">
                            <field name="config_id"/>
                            <field name="job_type"/>
                            <field name="status"/>
                            <field name="records_processed"/>
                        </group>
                        <group string="Timestamps">
                            <field name="create_date" readonly="1"/>
                            <field name="complete_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Details">
                        <field name="message" readonly="1" nolabel="1"/>
                        <field name="errors" readonly="1" nolabel="1" placeholder="No errors"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

