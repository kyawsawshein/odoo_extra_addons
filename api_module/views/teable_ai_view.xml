    <!-- Action for Sync Jobs -->
    <record id="action_teable_ai" model="ir.actions.act_window">
        <field name="name">Teable AI</field>
        <field name="res_model">teable.ai</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Teable AI will appear here after you run sync operations!
            </p>
        </field>
