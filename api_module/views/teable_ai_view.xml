<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sync Table List View -->
    <record id="view_teable_ai_list" model="ir.ui.view">
        <field name="name">teable.ai.list</field>
        <field name="model">teable.ai</field>
        <field name="arch" type="xml">
            <list string="Table ID" editable="bottom">
                <field name="name"/>
                <field name="table"/>
            </list>
        </field>
    </record>

    <!-- Action for Sync Table -->
    <record id="action_teable_ai" model="ir.actions.act_window">
        <field name="name">Teable AI</field>
        <field name="res_model">teable.ai</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Teable AI will appear here after you run sync operations!
            </p>
        </field>
    </record>

</odoo>
