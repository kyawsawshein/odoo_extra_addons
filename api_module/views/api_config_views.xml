    <!-- Action for API Configuration -->
    <record id="action_api_config" model="ir.actions.act_window">
        <field name="name">API Configurations</field>
        <field name="res_model">api.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first API configuration to start syncing data!
            </p>
        </field>
    </record>
</odoo>