<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- API Configuration Form View -->
    <record id="view_api_config_form" model="ir.ui.view">
        <field name="name">api.config.form</field>
        <field name="model">api.config</field>
        <field name="arch" type="xml">
            <form string="API Configuration">
                <header>
                    <button name="authenticate" type="object" string="Test Connection" class="btn-primary"/>
                    <button name="sync_contacts_from_odoo" type="object" string="Sync Contacts" class="btn-secondary"/>
                    <button name="sync_products_from_odoo" type="object" string="Sync Products" class="btn-secondary"/>
                    <button name="sync_all_data" type="object" string="Sync All" class="btn-secondary"/>
                    <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                </header>
                <sheet>
                    <group>
                        <group string="Basic Information">
                            <field name="name" required="1"/>
                            <field name="active"/>
                        </group>
                        <group string="API Settings">
                            <field name="api_url" required="1"/>
                            <field name="auth_url" required="0"/>
                            <field name="graphql_url" required="0"/>
                            <field name="database" required="0"/>
                            <field name="token_key" placeholder="Token Key"/>
                            <field name="username" required="0"/>
                            <field name="password" required="0" password="True"/>
                        </group>
                    </group>
                    <group string="Authentication Status">
                        <field name="token" readonly="1" nolabel="1" placeholder="Token will appear after successful authentication"/>
                        <field name="token_expiry" readonly="1"/>
                    </group>
                    <group string="JWT Authentication">
                        <field name="enable_jwt_auth"/>
                        <!-- attrs="{'invisible': [('enable_jwt_auth', '=', False)]}" -->
                        <field name="jwt_secret" password="True"/>
                        <field name="jwt_algorithm"/>
                        <field name="audience"/>
                        <field name="issuer"/>
                    </group>
                    <group string="Sync Settings">
                        <group>
                            <field name="sync_contacts"/>
                            <field name="sync_products"/>
                        </group>
                        <group>
                            <field name="sync_interval"/>
                            <field name="last_sync_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- API Configuration List View -->
    <record id="view_api_config_list" model="ir.ui.view">
        <field name="name">api.config.list</field>
        <field name="model">api.config</field>
        <field name="arch" type="xml">
            <list string="API Configurations">
                <field name="name"/>
                <field name="api_url"/>
                <field name="active"/>
                <field name="enable_jwt_auth"/>
                <field name="sync_contacts"/>
                <field name="sync_products"/>
                <field name="last_sync_date"/>
            </list>
        </field>
    </record>

