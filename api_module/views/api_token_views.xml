<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- API Token Tree View -->
    <record id="view_api_token_list" model="ir.ui.view">
        <field name="name">api.token.list</field>
        <field name="model">api.token</field>
        <field name="arch" type="xml">
        <!-- decoration-danger="not is_active or (expires_at and expires_at context_today()) -->
            <list string="API Tokens">
                <field name="name"/>
                <field name="user_id"/>
                <field name="is_active"/>
                <field name="expires_at"/>
                <field name="created_at"/>
            </list>
        </field>
    </record>

    <!-- API Token Form View -->
    <record id="view_api_token_form" model="ir.ui.view">
        <field name="name">api.token.form</field>
        <field name="model">api.token</field>
        <field name="arch" type="xml">
            <form string="API Token">
                <header>
                    <button name="action_renew" type="object" string="Renew Token" class="btn-secondary"/>
                    <button name="action_generate_new" type="object" string="Generate New Token" class="btn-warning" confirm="This will invalidate the current token. Are you sure?"/>
                    <field name="is_active" widget="boolean_button" options='{"terminology": "archive"}'/>
                </header>
                <sheet>
                    <group>
                        <group string="Token Information">
                            <field name="name" required="1"/>
                            <field name="user_id" required="1"/>
                            <field name="is_active"/>
                        </group>
                        <group string="Token Details">
                            <field name="token" readonly="1" password="True" nolabel="1" placeholder="Token will be generated automatically"/>
                            <field name="expires_at"/>
                            <field name="created_at" readonly="1"/>
                        </group>
                    </group>
                    <group string="Scopes">
                        <field name="scopes" nolabel="1" placeholder='["products.read", "contacts.read", "purchases.read", "sales.read", "inventory.read", "invoices.read"]'/>
                        <label for="scopes"/>
                        <div class="alert alert-info" role="alert">
                            <strong>Scopes Format:</strong> JSON array of allowed permissions. Example: ["products.read", "contacts.write"]
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

