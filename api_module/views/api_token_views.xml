    <!-- Action for API Tokens -->
    <record id="action_api_token" model="ir.actions.act_window">
        <field name="name">API Tokens</field>
        <field name="res_model">api.token</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first API token to enable external API access!
            </p>
        </field>
    </record>

    <!-- Menu Items for API Tokens -->
    <menuitem id="menu_api_module_tokens" name="API Tokens" parent="menu_api_module_config" action="action_api_token" sequence="20"/>
